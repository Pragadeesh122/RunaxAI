# -----------------------------------------------------------------------------
# RunaxAI / AgenticRag Environment Configuration
# Copy this file to .env and fill in the required values.
# -----------------------------------------------------------------------------

# --- LLM Providers ---
# At least one provider key is required for chat and embeddings.
OPENAI_API_KEY=your_openai_api_key
ANTHROPIC_API_KEY=your_anthropic_api_key
GEMINI_API_KEY=your_gemini_api_key
GROQ_API_KEY=your_groq_api_key

# --- Vector Database (Pinecone) ---
PINECONE_API_KEY=your_pinecone_api_key
PINECONE_ENVIRONMENT=your_pinecone_env
PINECONE_INDEX_NAME=agenticrag

# --- Relational Database (PostgreSQL) ---
DB_HOST=localhost
DB_PORT=5432
DB_NAME=agenticrag
DB_USER=admin
DB_PASSWORD=admin
DB_ADMIN_USER=admin
DB_ADMIN_PASSWORD=admin

# --- Redis (Sessions, Caching, Job Queue) ---
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# --- Object Storage (MinIO) ---
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_SECURE=false
MINIO_PUBLIC_BASE_URL=http://localhost:9000

# --- Authentication ---
# Generate a random secret for JWT signing (e.g. `openssl rand -hex 32`)
SECRET_KEY=super-secret-default-key-keep-private
# Google OAuth (Optional)
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# --- Frontend & Networking ---
FRONTEND_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:8000
CORS_ALLOWED_ORIGINS=http://localhost:3000

# --- Observability & Logging ---
# Enable/Disable detailed tracing and metrics
ENABLE_API_DOCS=true
LOG_LEVEL=INFO
OTEL_EXPORTER=console

# --- Adaptive RAG Settings (Optional) ---
RETRIEVAL_CACHE_AUDIT_RATE=0.05
DENSE_EMBEDDING_MODEL=text-embedding-3-large
SMALL_EMBEDDING_MODEL=text-embedding-3-small
