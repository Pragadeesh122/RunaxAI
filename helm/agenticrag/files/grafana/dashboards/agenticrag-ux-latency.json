    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "description": "Time-to-first-token percentiles across all streaming LLM calls.",
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "decimals": 2,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 1.5},
              {"color": "red", "value": 3}
            ]
          }
        },
        "overrides": []
      },
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 0},
      "id": 1,
      "options": {"legend": {"displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"]}},
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum by (le) (rate(agenticrag_llm_ttft_seconds_bucket[5m])))",
          "legendFormat": "p50",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum by (le) (rate(agenticrag_llm_ttft_seconds_bucket[5m])))",
          "legendFormat": "p95",
          "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.99, sum by (le) (rate(agenticrag_llm_ttft_seconds_bucket[5m])))",
          "legendFormat": "p99",
          "refId": "C"
