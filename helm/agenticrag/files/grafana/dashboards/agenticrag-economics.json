{
  "annotations": {"list": []},
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 0,
  "id": null,
  "links": [],
  "panels": [
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "description": "Total estimated LLM spend over the selected time range.",
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "decimals": 4,
          "color": {"mode": "thresholds"},
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 10},
              {"color": "red", "value": 50}
            ]
          }
        },
        "overrides": []
      },
      "gridPos": {"h": 5, "w": 6, "x": 0, "y": 0},
      "id": 1,
      "options": {
        "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false},
        "textMode": "auto",
        "colorMode": "value",
        "graphMode": "area"
      },
      "pluginVersion": "10.0.0",
      "targets": [
        {
          "expr": "sum(increase(agenticrag_llm_spend_usd_total[$__range]))",
          "instant": true,
          "legendFormat": "Total Spend",
          "refId": "A"
        }
      ],
      "title": "Total LLM Spend",
      "type": "stat"
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "description": "Total LLM requests over the selected time range.",
      "fieldConfig": {"defaults": {"unit": "short", "decimals": 0}, "overrides": []},
      "gridPos": {"h": 5, "w": 6, "x": 6, "y": 0},
      "id": 2,
      "options": {
        "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false},
        "textMode": "auto",
        "colorMode": "value",
        "graphMode": "area"
      },
      "targets": [
        {
          "expr": "sum(increase(agenticrag_llm_requests_total[$__range]))",
          "instant": true,
          "legendFormat": "Requests",
          "refId": "A"
        }
      ],
      "title": "Total LLM Requests",
      "type": "stat"
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "description": "Total prompt + completion tokens consumed in the selected range.",
      "fieldConfig": {"defaults": {"unit": "short", "decimals": 0}, "overrides": []},
      "gridPos": {"h": 5, "w": 6, "x": 12, "y": 0},
      "id": 3,
      "options": {
        "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false},
        "textMode": "auto",
        "colorMode": "value",
        "graphMode": "area"
      },
      "targets": [
        {
          "expr": "sum(increase(agenticrag_llm_tokens_total[$__range]))",
          "instant": true,
          "legendFormat": "Tokens",
          "refId": "A"
        }
      ],
      "title": "Total Tokens",
      "type": "stat"
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "description": "Average cost per 1K tokens across all models in the selected range.",
      "fieldConfig": {
        "defaults": {"unit": "currencyUSD", "decimals": 4},
        "overrides": []
      },
      "gridPos": {"h": 5, "w": 6, "x": 18, "y": 0},
      "id": 4,
      "options": {
        "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false},
        "textMode": "auto",
        "colorMode": "value",
        "graphMode": "area"
      },
      "targets": [
        {
          "expr": "(1000 * sum(increase(agenticrag_llm_spend_usd_total[$__range]))) / clamp_min(sum(increase(agenticrag_llm_tokens_total[$__range])), 1)",
          "instant": true,
          "legendFormat": "$ / 1K tokens",
          "refId": "A"
        }
      ],
      "title": "Blended Cost / 1K Tokens",
      "type": "stat"
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "description": "Actual USD spent per model in each step of the selected range. Stacked — the sum across steps equals the 'Total LLM Spend' stat above. Uses increase() so there is no hourly projection of short bursts.",
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "decimals": 4,
          "custom": {
            "drawStyle": "bars",
            "fillOpacity": 80,
            "lineWidth": 0,
            "stacking": {"mode": "normal", "group": "A"}
          }
        },
        "overrides": []
      },
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 5},
      "id": 5,
      "options": {"legend": {"displayMode": "table", "placement": "bottom", "calcs": ["sum"]}},
      "targets": [
        {
          "expr": "sum by (model) (increase(agenticrag_llm_spend_usd_total[$__rate_interval]))",
          "legendFormat": "{{model}}",
          "refId": "A"
        }
      ],
      "title": "Spend by Model (USD per step)",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "description": "Share of total spend by chat type (general vs project) over the selected range.",
      "fieldConfig": {
        "defaults": {"unit": "currencyUSD", "decimals": 4},
        "overrides": []
      },
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 5},
      "id": 6,
      "options": {
        "legend": {"displayMode": "table", "placement": "right", "values": ["value", "percent"]},
        "pieType": "donut",
        "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false}
      },
      "targets": [
        {
          "expr": "sum by (chat_type) (increase(agenticrag_llm_spend_usd_total[$__range]))",
          "instant": true,
          "legendFormat": "{{chat_type}}",
          "refId": "A"
        }
      ],
      "title": "Spend by Chat Type",
      "type": "piechart"
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "description": "Top users by total spend across sessions over the selected range. High-cardinality: disabled when OBS_ENABLE_HIGH_CARDINALITY_METRICS is false.",
      "fieldConfig": {
        "defaults": {"unit": "currencyUSD", "decimals": 4},
        "overrides": []
      },
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 13},
      "id": 7,
      "options": {
        "orientation": "horizontal",
        "displayMode": "gradient",
        "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false},
        "showUnfilled": true
      },
      "targets": [
        {
          "expr": "topk(10, sum by (user_hash) (increase(agenticrag_llm_session_spend_usd_total[$__range])))",
          "instant": true,
          "legendFormat": "{{user_hash}}",
          "refId": "A"
        }
      ],
      "title": "Top 10 Users by Spend",
      "type": "bargauge"
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "description": "Top sessions by total tokens over the selected range.",
      "fieldConfig": {
        "defaults": {"unit": "short", "decimals": 0},
        "overrides": []
      },
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 13},
      "id": 8,
      "options": {
        "orientation": "horizontal",
        "displayMode": "gradient",
        "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false},
        "showUnfilled": true
      },
      "targets": [
        {
          "expr": "topk(10, sum by (session_hash) (increase(agenticrag_llm_session_tokens_total[$__range])))",
          "instant": true,
          "legendFormat": "{{session_hash}}",
          "refId": "A"
        }
      ],
      "title": "Top 10 Sessions by Tokens",
      "type": "bargauge"
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "description": "Prompt vs completion token volume per model over the selected range.",
      "fieldConfig": {"defaults": {"unit": "short", "decimals": 0}, "overrides": []},
      "gridPos": {"h": 8, "w": 16, "x": 0, "y": 21},
      "id": 9,
      "options": {
        "showHeader": true,
        "cellHeight": "sm",
        "footer": {"show": true, "reducer": ["sum"], "fields": ["Value"]}
      },
      "targets": [
        {
          "expr": "sum by (model, token_type) (increase(agenticrag_llm_tokens_total[$__range]))",
          "instant": true,
          "legendFormat": "{{model}} | {{token_type}}",
          "format": "table",
          "refId": "A"
        }
      ],
      "title": "Tokens by Model & Type",
      "type": "table"
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "description": "Share of LLM responses where usage metadata was not provided by the provider (lowers cost accuracy). Includes 'usage_missing' and 'usage_estimated' statuses.",
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "decimals": 2,
          "min": 0,
          "max": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 0.1},
              {"color": "red", "value": 0.25}
            ]
          }
        },
        "overrides": []
      },
      "gridPos": {"h": 8, "w": 8, "x": 16, "y": 21},
      "id": 10,
      "options": {"legend": {"displayMode": "list", "placement": "bottom"}},
      "targets": [
        {
          "expr": "sum(rate(agenticrag_llm_requests_total{status=~\"usage_missing|usage_estimated\"}[5m])) / clamp_min(sum(rate(agenticrag_llm_requests_total[5m])), 0.0001)",
          "legendFormat": "usage_not_exact",
          "refId": "A"
        }
      ],
      "title": "Usage Missing / Estimated Rate",
      "type": "timeseries"
    }
  ],
  "refresh": "30s",
  "schemaVersion": 39,
  "style": "dark",
  "tags": ["agenticrag", "economics"],
  "templating": {"list": []},
  "time": {"from": "now-24h", "to": "now"},
  "timezone": "browser",
  "title": "RunaxAI - Economics",
  "uid": "agenticrag-econ-v1",
  "version": 2
}
